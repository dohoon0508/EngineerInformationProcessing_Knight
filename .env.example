# 카카오 로그인 (웹 JavaScript 키만 프론트에 사용)
# https://developers.kakao.com → 앱 → 플랫폼 키
VITE_KAKAO_JAVASCRIPT_KEY=

# 기기 간 통계 동기화 (선택) — Vercel 배포 + Neon DB 연결 시
# true / 1 / yes — 배포 도메인의 /api/stats 로 업·다운로드 (Vercel 빌드에 반영되므로 재배포 필요)
VITE_ENABLE_CLOUD_SYNC=false
# 비우면 현재 origin 사용. 별도 API 도메인이면 https://xxx.vercel.app 만 입력
VITE_STATS_API_BASE=

# ---- Vercel 서버 환경 변수 (로컬 .env 에 넣어도 gitignore 됨) ----
# Neon 등 PostgreSQL 연결 문자열 (없으면 동기화 API는 503)
DATABASE_URL=

# 카카오 Admin 키: 브라우저에 절대 넣지 말 것. 서버 전용 API(푸시 등)에만 사용.
# 현재 통계 API는 사용자 액세스 토큰으로 본인 확인만 하며 Admin 키는 필수 아님.
# KAKAO_ADMIN_KEY=
