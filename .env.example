# 로컬에서만 덮어쓰기: `.env.local` (Vite가 `.env`보다 우선, `.gitignore`에 포함됨)
#
# 카카오 로그인 (웹 JavaScript 키만 프론트에 사용)
# https://developers.kakao.com → 앱 → 플랫폼 키
VITE_KAKAO_JAVASCRIPT_KEY=
# (선택) Auth.authorize·토큰 교환에 쓰는 redirect_uri — 콘솔 등록값과 문자 단위로 같아야 함
# 비우면 자동으로 {현재 origin}/login (예: http://localhost:5173/login)
# 끝 슬래시·경로가 콘솔과 다르면 여기서 전체 URL을 고정: VITE_KAKAO_REDIRECT_URI=http://localhost:5173/login
# 또는 경로만: VITE_KAKAO_REDIRECT_PATH=/login
VITE_KAKAO_REDIRECT_URI=
VITE_KAKAO_REDIRECT_PATH=

# 기기 간 통계 동기화 (선택) — Vercel 배포 + Neon DB 연결 시
# true / 1 / yes — 배포 도메인의 /api/stats 로 업·다운로드 (Vercel 빌드에 반영되므로 재배포 필요)
VITE_ENABLE_CLOUD_SYNC=false
# 비우면 현재 origin 사용. 별도 API 도메인이면 https://xxx.vercel.app 만 입력
VITE_STATS_API_BASE=
# (선택) 로컬 vite dev 시 /api 만 프록시할 주소. 비우면 VITE_STATS_API_BASE 또는 README 배포 URL 사용
# VITE_DEV_API_PROXY=https://engineerinformationprocessingknight.vercel.app

# ---- Vercel 서버 환경 변수 (로컬 .env 에 넣어도 gitignore 됨) ----
# 카카오 로그인 (Auth.authorize → /api/kakao-token) — REST API 키 + 클라이언트 시크릿 (절대 VITE_ 로 넣지 말 것)
# 토큰 요청 시 client_id 로 사용. JS 키와 헷갈리지 말 것.
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
# (선택) 토큰 API가 허용할 redirect 경로(쉼표 구분). 프론트가 보내는 redirect_uri 의 pathname 이 목록에 있어야 함. 예: /login,/login/,/auth/kakao/callback
# KAKAO_OAUTH_REDIRECT_PATHS=/login

# Neon 등 PostgreSQL 연결 문자열 (없으면 동기화 API는 503)
DATABASE_URL=

# 관리자 요약 API(/api/admin-overview) 및 브라우저 /admin 페이지 — 임의의 긴 문자열. VITE_ 로 절대 노출하지 말 것.
# ADMIN_DASHBOARD_SECRET=

# 카카오 Admin 키: 브라우저에 절대 넣지 말 것. 서버 전용 API(푸시 등)에만 사용.
# 현재 통계 API는 사용자 액세스 토큰으로 본인 확인만 하며 Admin 키는 필수 아님.
# KAKAO_ADMIN_KEY=
